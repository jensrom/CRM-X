# ============================================================
# CRM-X Environment Variables
# Kopiér denne fil til .env.local og udfyld værdierne
# VIGTIG: Del ALDRIG .env.local offentligt
# ============================================================

# --- Database (Neon PostgreSQL) ---
# Opret gratis konto på neon.tech → Nyt projekt "crm-x" → Kopiér BÅDE pooled og direct
# DATABASE_URL = pooled (med ?pgbouncer=true) — bruges af app i runtime
# DIRECT_URL   = direct (uden pooler) — bruges af Prisma migrations
DATABASE_URL="postgresql://username:password@host-pooler/crm_x?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://username:password@host/crm_x?sslmode=require"

# --- NextAuth.js ---
# Generér med: openssl rand -base64 32
# VIGTIG: Skal være præcis den samme værdi mellem dev og prod, ellers logges alle ud
NEXTAUTH_SECRET="din-super-hemmelige-nogle-her"
# Bagudkompat-alias (nogle libs læser AUTH_SECRET) — sæt til samme værdi
AUTH_SECRET="din-super-hemmelige-nogle-her"

# URL til din app (lokalt: http://localhost:3000, prod: https://plesnertech.dk)
NEXTAUTH_URL="http://localhost:3000"

# --- Resend (email) ---
# Opret konto på resend.com → API Keys → Create API Key
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="noreply@plesnertech.dk"

# --- Vercel Blob (fil-upload) ---
# Tilgængeligt automatisk i Vercel deployment
# Lokalt: opret via Vercel CLI: vercel env pull
BLOB_READ_WRITE_TOKEN=""

# --- App konfiguration ---
# Basis-domæne for tenants (fx plesnertech.dk → kunde.plesnertech.dk)
NEXT_PUBLIC_ROOT_DOMAIN="plesnertech.dk"
NEXT_PUBLIC_APP_URL="https://app.plesnertech.dk"

# --- Super Admin (første setup) ---
# Bruges kun til initial seed - skift derefter i admin portalen
SUPER_ADMIN_EMAIL="jens@plesnertech.dk"
SUPER_ADMIN_PASSWORD="SkiftMigStraks!"

# --- MFA secret-kryptering (AES-256-GCM, 32 bytes base64) ---
# Generér med: openssl rand -base64 32
MFA_ENCRYPTION_KEY=""
